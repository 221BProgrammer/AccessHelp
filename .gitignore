# ════════════════════════════════════════════════════════════════
#  AccessHelp — .gitignore
#  Everything listed here is excluded from GitHub.
#  Reason for each section is explained below.
# ════════════════════════════════════════════════════════════════


# ── 1. PYTHON CACHE & BUILD FILES ────────────────────────────────
# Auto-generated by Python — never needed in a repo
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
lib/
lib64/
wheels/
*.spec


# ── 2. VIRTUAL ENVIRONMENTS ──────────────────────────────────────
# Your local Python environment — each developer creates their own
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.virtualenv/
# venv310 folder found at your project root
venv310/


# ── 3. ENVIRONMENT / SECRET FILES — CRITICAL, NEVER COMMIT ──────
# Contains Twilio API keys, email passwords etc.
# If committed, attackers can use your Twilio account and run up bills.
.env
.env.local
.env.production
.env.development
*.env
secrets.py
config_secrets.py


# ── 4. TRAINED MODEL FILES ───────────────────────────────────────
# sign_model.pkl is large (~50-200MB) and reproducible by running
# dataset_from_images.py + train.py — no need to store in git.
# README documents exactly how to retrain it.
sign_model.pkl
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
*.tflite
*.pb
saved_model/


# ── 5. TRAINING DATASETS — LARGE, COPYRIGHTED ────────────────────
# grassknoted/asl-alphabet: ~1GB, 87,000 images
# WLASL: ~10GB+, 21,000 videos
# asl-numbers: additional number sign images
# These are downloaded separately by each developer (README explains where)
datasets/
data/signs/
data/alphabet/
data/alphabets/
data/alphabets.json


# ── 6. WLASL EXTRACTED FRAMES ────────────────────────────────────
# Generated by wlasl_extract.py — thousands of JPG frames from videos
# Each developer regenerates these from the downloaded videos
datasets/wlasl_frames/


# ── 7. SIGN LANGUAGE ANIMATION ASSETS — LARGE MEDIA FILES ────────
# .mp4 files: your collected A-Z alphabet videos (a.mp4, b.mp4 etc.)
# .gif files: word sign animations
# .webm files: alternative video format
# .png/.jpg in sign_assets: downloaded sign images
# EXCEPTION: .svg placeholder files ARE committed (tiny, auto-generated,
# useful so the app doesn't crash when real videos are missing)
src/vision/sign_assets/*.mp4
src/vision/sign_assets/*.gif
src/vision/sign_assets/*.webm
src/vision/sign_assets/*.png
src/vision/sign_assets/*.jpg
src/vision/sign_assets/*.jpeg
!src/vision/sign_assets/*.svg


# ── 8. USER RUNTIME DATA — PRIVATE / PERSONAL ────────────────────
# Contains real names, phone numbers, email addresses of emergency contacts.
# Contains personal user preferences and saved phrases.
# None of this should ever be public.
data/user_profiles.json
data/emergency_contacts.json
data/emergency_log.txt
data/phrases.json
# phrases.json also exists at the project root level
phrases.json


# ── 9. AUDIO TEMP FILES ───────────────────────────────────────────
# Created temporarily during TTS playback and STT recording.
# Deleted automatically after use but sometimes left behind on crash.
*.mp3
*.wav
temp.wav
temp_voice.wav
voice_command.wav


# ── 10. LOG FILES ────────────────────────────────────────────────
# Generated by error_handler.py and Python logging.
# Can contain stack traces with file paths and system info.
logs/
*.log
*.log.*
accesshelp_*.log


# ── 11. JUPYTER NOTEBOOKS ────────────────────────────────────────
# Output cells can contain large arrays, images, and personal data.
# Commit only the .ipynb if needed — never the checkpoint folder.
.ipynb_checkpoints/


# ── 12. IDE AND EDITOR FILES ─────────────────────────────────────
# Each developer uses their own editor settings.
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/


# ── 13. OPERATING SYSTEM FILES ───────────────────────────────────
# macOS filesystem metadata (created automatically on Mac)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Windows thumbnail cache and desktop config
ehthumbs.db
Thumbs.db
desktop.ini
# Linux
*~


# ── 14. STREAMLIT ────────────────────────────────────────────────
# secrets.toml can contain API keys if configured there
.streamlit/secrets.toml


# ── 15. REACT / NODE.JS (for FastAPI + React migration) ──────────
# Entire frontend folder ignored — not usable yet
# When ready to integrate, remove 'frontend/' line and use the specific rules below instead:
# frontend/node_modules/
# frontend/build/
# frontend/.env
# frontend/.env.local
# frontend/.env.production
frontend/


# ── 16. TESTING ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml


# ── 17. TEMPORARY FILES ──────────────────────────────────────────
# Various temp files created during processing
*.tmp
*.temp
tmp/
temp/
voice_command.wav
temp.wav
temp_voice.wav


# ── 18. BACKGROUND IMAGES (optional — check file sizes) ──────────
# If your background images are under 5MB, you CAN commit them
# so the app looks correct for anyone who clones it.
# If they are large (>5MB each), uncomment these lines:
# assets/images/sakura-bg.jpg
# assets/images/night-bg.jpg


# ── 19. PERSONAL NOTES (optional) ────────────────────────────────
# further_improvements.txt contains your personal development notes.
# Uncomment the line below if you don't want it visible on GitHub:
# further_improvements.txt


# ════════════════════════════════════════════════════════════════
#  WHAT IS INTENTIONALLY COMMITTED (not ignored):
# ════════════════════════════════════════════════════════════════
#
#  ✅ All .py source files (entire src/ folder)
#  ✅ main.py, ui.py
#  ✅ requirements.txt
#  ✅ README.md
#  ✅ .gitignore (this file)
#  ✅ src/vision/sign_assets/*.svg  (tiny placeholder SVGs only)
#  ✅ assets/images/*.jpg  (background images if small enough)
#  ✅ data/  folder itself (empty, but kept so the folder exists)
#
#  ❌ Everything else listed above is excluded.
#
# ════════════════════════════════════════════════════════════════